root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
# CA1707: Identifiers should not contain underscores
# Suppressed in test projects where Method_Scenario_Expected is standard xUnit convention
dotnet_diagnostic.CA1707.severity = warning

# CA1848: Use LoggerMessage delegates for performance
# Suppressed globally — perf benefit is negligible for this project's log volume
dotnet_diagnostic.CA1848.severity = none

# CA1873: Avoid computing parameters when logging is disabled
# Suppressed — our log calls use simple string parameters, not expensive computations
dotnet_diagnostic.CA1873.severity = none

[tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none

# Node.js API simulator — must expose the same algorithm and type names as Node itself.
[src/EcmaScript/SuperRender.EcmaScript.NodeSimulator/**/*.cs]
# CA5350/CA5351: broken/weak crypto — Node.js `crypto` exposes MD5/SHA1 by name
dotnet_diagnostic.CA5350.severity = none
dotnet_diagnostic.CA5351.severity = none
# CA1711: "Stream" suffix on type names — Node.js calls them Readable/Writable/TransformStream
dotnet_diagnostic.CA1711.severity = none
